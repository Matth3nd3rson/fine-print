{
  "manifest_version": 3,
  "name": "Fine Print",
  "version": "1.0.0",
  "description": "Detects Terms of Service and Privacy Policies, then flags red flags and gotchas using AI.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fine Print"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
